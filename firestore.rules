rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Allow if auth is not null and document has admin role OR they are in predefined emails
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email != null && request.auth.token.email.lower() in ['satyammasterofai@gmail.com', 'jhahimanshukumar87@gmail.com', 'sigmaphotography0001@gmail.com'])
      );
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read/write their own profile
      // Admins can read/write any profile
      // Anyone can create their profile when they first log in (or at least users can write to their own uid)
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Website Management Collections
    // Public read for things that are shown on frontend
    
    match /templates/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /faqs/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      // Users can read/update their own orders, admins can read/update all
      allow read, update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /order_files/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{document=**} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
